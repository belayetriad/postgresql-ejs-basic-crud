<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>Student Profile</title>

    <style>
      body {
        font-family: Arial;
        background: #f4f6f8;
        padding: 40px;
      }
      /* ✅ Top bar */
      .topbar {
        max-width: 1100px;
        margin: 0 auto 18px auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        padding: 12px 14px;
        background: rgba(255, 255, 255, 0.85);
        border: 1px solid var(--border);
        border-radius: 12px;
        box-shadow: 0 6px 20px rgba(0, 0, 0, 0.04);
        backdrop-filter: blur(6px);
        flex-wrap: wrap; /* ✅ important */
      }

      .brand {
        display: flex;
        align-items: center;
        gap: 10px;
        min-width: 240px;
      }

      .brand img {
        width: 42px;
        height: 42px;
        object-fit: contain;
        border-radius: 10px;
        background: #fff;
        border: 1px solid var(--border);
        padding: 6px;
        flex-shrink: 0;
      }

      .brand .title {
        display: flex;
        flex-direction: column;
        line-height: 1.1;
      }

      .brand .title strong {
        font-size: 15px;
      }

      .brand .title span {
        font-size: 12px;
        color: var(--muted);
      }

      .badge {
        font-size: 13px;
        color: var(--muted);
        border: 1px dashed var(--border);
        padding: 8px 10px;
        border-radius: 999px;
        background: #fff;
        white-space: nowrap;
      }

      .card {
        max-width: 600px;
        margin: auto;
        background: white;
        padding: 30px;
        border-radius: 12px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);
      }

      .profile {
        text-align: center;
        margin-bottom: 20px;
      }

      .profile img {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        object-fit: cover;
        border: 3px solid #eee;
      }

      .name {
        font-size: 22px;
        font-weight: bold;
        margin-top: 10px;
      }

      .meta {
        margin-top: 20px;
      }

      .row {
        margin-bottom: 12px;
      }

      .label {
        font-weight: bold;
        color: #555;
      }

      .back {
        display: inline-block;
        margin-top: 20px;
        padding: 10px 14px;
        background: #2563eb;
        color: white;
        text-decoration: none;
        border-radius: 8px;
      }
    </style>
  </head>

  <body>
    <div class="topbar">
      <div class="brand">
        <!-- Put logo at: src/public/logo.png -->
        <img src="/logo.png" alt="Logo" />
        <div class="title">
          <strong>Stanton Univarsity</strong>
          <span>TypeScript + PostgreSQL (Template Based)</span>
        </div>
      </div>
    </div>
    <div class="card">
      <div class="profile">
        <img src="<%= student.photo || '/default-avatar.png' %>" />

        <div class="name">
          <%= student.first_name %> <%= student.last_name %>
        </div>
      </div>

      <div class="meta">
        <div class="row">
          <span class="label">Roll:</span>
          <%= student.roll %>
        </div>

        <div class="row">
          <span class="label">Registration:</span>
          <%= student.registration %>
        </div>

        <div class="row">
          <span class="label">Email:</span>
          <%= student.email %>
        </div>

        <div class="row">
          <span class="label">Address:</span>
          <%= student.address %>
        </div>
      </div>

      <a class="back" href="/">⬅ Back to Students</a>
    </div>
  </body>
</html>
